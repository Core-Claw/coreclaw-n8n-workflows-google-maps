            }
          ],
          "combinator": "and"
        },
        "options": {}
      }
    },
    {
      "id": "get-run-results",
      "name": "Get Run Results / 获取结果",
      "type": "n8n-nodes-coreclaw.coreClaw",
      "typeVersion": 1,
      "position": [
        380,
        -100
      ],
      "parameters": {
        "resource": "run",
        "operation": "getResults",
        "runSlug": "={{ $('Start CoreClaw Run / 启动CoreClaw').item.json.run_slug }}",
        "returnAll": false,
        "limit": "={{ Number($items(\"Input Config / 输入配置\")?.[0]?.json?.limit || 10) }}"
      },
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 5000,
      "notesInFlow": true,
      "notes": "Select your CoreClaw API credential after import."
    },
    {
      "id": "normalize-records",
      "name": "Normalize Records / 规范化记录",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        640,
        -100
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "return $input.all().map((item,index)=>{const r=item.json; const followers=Number(r.followers_count||r.followers||0); const posts=Number(r.posts_count||r.posts||0); const verified=Boolean(r.is_verified); const score=Math.min(100,(verified?30:0)+(followers>1000000?40:followers>100000?30:followers>10000?20:10)+(posts>100?15:5)); return {json:{record_key:String(r.id||r.account||r.profile_url||index).toLowerCase(),workflow_kind:'instagram_profile_intel',account:r.account||'',profile_name:r.profile_name||r.full_name||'',profile_url:r.profile_url||r.url||'',followers_count:followers,posts_count:posts,is_verified:verified,is_business_account:r.is_business_account,opportunity_score:score,priority:score>=70?'high':'normal',action:score>=70?'Shortlist for influencer or brand partnership review.':'Monitor profile for later campaign fit.',raw:r}}});"
      }
    },
    {
      "id": "remove-duplicates",
      "name": "Remove Duplicates / 去重",
      "type": "n8n-nodes-base.removeDuplicates",
      "typeVersion": 2,
      "position": [
        900,
        -100
      ],
      "parameters": {
        "compare": "selectedFields",
        "fieldsToCompare": "record_key",
        "options": {}
      }
    },
    {
      "id": "loop-items",
      "name": "Loop Items / 逐条处理",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [
        1160,
        -100
      ],
      "parameters": {
        "batchSize": 1,
        "options": {}
      }
    },
    {
      "id": "ai-analysis",
      "name": "AI Analysis / AI分析",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1420,
        -100
      ],
      "parameters": {
        "method": "POST",
        "url": "https://maas-coding-api.cn-huabei-1.xf-yun.com/v2/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer YOUR_LLM_API_KEY"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "jsonBody": "={{ ({ model: 'astron-code-latest', temperature: 0.2, messages: [{ role: 'system', content: 'Return concise JSON only for commercial workflow automation.' }, { role: 'user', content: 'Analyze this record for business use. Return JSON fields: opportunity, risk, action, priority. Record: ' + JSON.stringify($json) }] }) }}",
        "options": {
          "timeout": 60000
        },
        "specifyBody": "json"
      }
    },
    {
      "id": "parse-ai",
      "name": "Parse AI / 解析AI",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1680,
        -100
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const sourceItems = $items('Remove Duplicates / 去重').map(item => item.json);\nreturn $input.all().map((item, index) => {\n  const source = sourceItems[index] || sourceItems[0] || {};\n  const body = item.json;\n  const content = body?.choices?.[0]?.message?.content || '{}';\n  const cleaned = String(content).replace(/^```json\\s*/i, '').replace(/^```\\s*/i, '').replace(/```$/i, '').trim();\n  let parsed = {};\n  try { parsed = JSON.parse(cleaned); } catch (error) { parsed = { raw: content }; }\n  return { json: { ...source, ai_opportunity: parsed.opportunity || '', ai_risk: parsed.risk || '', ai_action: parsed.action || '', ai_priority: parsed.priority || '', ai_raw: parsed } };\n});"
      }
    },
    {
      "id": "route-priority",
      "name": "Route Priority / 优先级分流",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.2,
      "position": [
        1940,
        -100
      ],
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "typeValidation": "strict",
                  "version": 2
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.priority || $json.ai_priority }}",
                    "rightValue": "high",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "High"
            }
          ]
        },
        "options": {
          "fallbackOutput": "extra",
          "renameFallbackOutput": "Normal"
        }
      }
    },
    {
      "id": "noop-high-priority-queue-",
      "name": "High Priority Queue / 高优先级队列",
      "type": "n8n-nodes-base.noOp",
