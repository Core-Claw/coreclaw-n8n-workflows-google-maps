      ],
      "parameters": {}
    },
    {
      "id": "prepare-payloads",
      "name": "Prepare Payloads / 准备载荷",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2460,
        -100
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "return $input.all().map(item=>({json:{...item.json,destination_payloads:{google_sheets:item.json,airtable:{fields:item.json},slack:{text:(item.json.title||item.json.account||'CoreClaw record')+' | '+(item.json.ai_action||item.json.action||'review')},notion:{title:item.json.title||item.json.account||item.json.record_key,properties:item.json}}}}));"
      }
    },
    {
      "id": "aggregate-results",
      "name": "Aggregate Results / 聚合结果",
      "type": "n8n-nodes-base.aggregate",
      "typeVersion": 1,
      "position": [
        2720,
        -100
      ],
      "parameters": {
        "aggregate": "aggregateAllItemData",
        "destinationFieldName": "records",
        "options": {}
      }
    },
    {
      "id": "markdown-report",
      "name": "Markdown Report / Markdown报告",
      "type": "n8n-nodes-base.markdown",
      "typeVersion": 1,
      "position": [
        2980,
        -100
      ],
      "parameters": {
        "mode": "markdownToHtml",
        "markdown": "=## CoreClaw Automation Report\n\n{{$json.records ? $json.records.length : 0}} records prepared for business operations."
      }
    },
    {
      "id": "success-summary",
      "name": "Success Summary / 成功摘要",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3240,
        -100
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const rows=$input.all().map(i=>i.json); const st=$items('Get Run Status / 获取状态')?.[0]?.json||{}; return [{json:{outcome:'success',workflow_name:'CoreClaw Instagram Profile Intel / Instagram主页情报',run_slug:$items('Start CoreClaw Run / 启动CoreClaw')?.[0]?.json?.run_slug||'',run_status:st.status,result_count:st.results,returned_items:rows.length,commercial_value:'Business-ready CoreClaw workflow with AI analysis, routing, payloads, and reporting.',sample:rows.slice(0,3),verified_at:new Date().toISOString()}}];"
      }
    },
    {
      "id": "failure-summary",
      "name": "Failure Summary / 失败摘要",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        380,
        240
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const st=$items('Get Run Status / 获取状态')?.[0]?.json||{}; return [{json:{outcome:'failure',workflow_name:'CoreClaw Instagram Profile Intel / Instagram主页情报',run_status:st.status,error:st.err_msg||'',verified_at:new Date().toISOString()}}];"
      }
    }
