      ],
      "parameters": {
        "resource": "scraper",
        "operation": "run",
        "scraperSlug": {
          "__rl": true,
          "mode": "id",
          "value": "01KPD6M5YVHWCNQCRK3W1JD9W2"
        },
        "version": "v1.0.2",
        "customParams": "={\n  \"username\": [{\"string\": \"{{ $json.username }}\"}]\n}"
      },
