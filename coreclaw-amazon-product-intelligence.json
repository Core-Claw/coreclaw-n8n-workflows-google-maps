      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const input=$items('Input Config / ????')?.[0]?.json||{}; return $input.all().map((item,index)=>{const r=item.json; const price=Number(String(r.price||r.final_price||'').replace(/[^0-9.]/g,''))||0; const rating=Number(r.rating||r.stars||0); const reviews=Number(String(r.reviews_count||r.review_count||'').replace(/[^0-9]/g,''))||0; const score=Math.min(100,Math.round((rating*12)+(reviews>1000?25:reviews>100?15:5)+(price?10:0))); return {json:{record_key:String(r.asin||r.url||r.title||index).toLowerCase(),workflow_kind:'amazon_product_intel',title:r.title||'',brand:r.brand||'',seller_name:r.seller_name||'',price,rating,review_count:reviews,url:r.url||r.product_url||'',keyword:input.keyword,opportunity_score:score,priority:score>=75?'high':'normal',action:score>=75?'Review pricing and positioning today.':'Track as benchmark product.',raw:r}}});"
      }
