      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1680,
        -100
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "return $input.all().map(item=>{const content=item.json.choices?.[0]?.message?.content||''; const cleaned=content.replace(/^s*```jsons*/i,'').replace(/```s*$/,'').trim(); let ai={}; try{ai=JSON.parse(cleaned)}catch(e){ai={raw:content}} const base=$items('Loop Items / ????')?.[0]?.json||{}; return {json:{...base,ai_opportunity:ai.opportunity||'',ai_risk:ai.risk||'',ai_action:ai.action||'',ai_priority:ai.priority||base.priority||'',ai_raw:ai}}})"
      }
    },
